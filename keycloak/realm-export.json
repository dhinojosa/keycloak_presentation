{
  "realm": "keycloak-demo",
  "enabled": true,
  "displayName": "Keycloak Presentation Demo",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "General user access"
      },
      {
        "name": "admin",
        "description": "Administrative access"
      },
      {
        "name": "engineering",
        "description": "Engineering access"
      },
      {
        "name": "sales",
        "description": "Sales access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "spring-app",
      "name": "Spring Demo App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "spring-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8081/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8081"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8081/*"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "quarkus-app",
      "name": "Quarkus Demo App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "quarkus-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8082/oidc/callback"
      ],
      "webOrigins": [
        "http://localhost:8082"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8082/*"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "kafka-broker",
      "name": "Kafka Broker",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kafka-broker-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "kafka-cli",
      "name": "Kafka CLI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kafka-cli-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "kafka-producer-app",
      "name": "Kafka Producer App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kafka-producer-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "kafka-consumer-app",
      "name": "Kafka Consumer App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kafka-consumer-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
      "username": "user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "user@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "email": "admin@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "admin"
      ]
    },
    {
      "username": "engineer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Engineer",
      "email": "engineer@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "engineering"
      ]
    },
    {
      "username": "sales",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Sales",
      "email": "sales@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "sales"
      ]
    }
  ]
}
